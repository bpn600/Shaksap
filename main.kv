                Lim_Key_Pad_Button:
                    text: "ᤏ"
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "ᤈ"
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "ᤘ"
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "ᤐ"
