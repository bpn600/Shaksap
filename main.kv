                    text: "ᤷ"
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "ᤸ"
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "."
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "ᤧ"
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "।"
                    on_release: root.insert_text(self.text)

        MDIconButton
            icon: 'blank'

    MDBoxLayout:
        id: number_row
        padding: dp(5)
        spacing: dp(12)
        size_hint_y: None
        height: dp(48)
        md_bg_color: app.theme_cls.primary_color

        MDIconButton:
            icon: 'apple-keyboard-shift'
            theme_text_color: "Custom"
            icon_color: app.theme_cls.accent_color if root.shift_state == 'shifted' else "white"
            size_hint: 1, 1
            on_release:
                root.cmd_sound()
                root.toggle_shift()

        MDIconButton:
            icon: 'text-box-minus-outline'
            theme_text_color: "Custom"
            icon_color: app.theme_cls.accent_color if root.shift_state == 'shifted' else "white"
            size_hint: 1, 1
            on_release:
                root.cmd_sound()
                root.clear_text_input()

        BoxLayout:
            id: number_row
            size_hint_x: None
            width: dp(150)

            MDRectangleFlatButton:
                text: "     Space     "
                theme_text_color: "Custom"
                text_color: "white"
                line_color: "white"
                size_hint: 1, 1
                on_release:
                    root.cmd_sound()
                    root.insert_space()

        MDIconButton:
            icon: 'backspace-outline'
            theme_text_color: "Custom"
            icon_color: app.theme_cls.accent_color if root.shift_state == 'shifted' else "white"
            size_hint: 1, 1
            on_release:
                root.cmd_sound()
                root.backspace()
                root.text_input.focus = True

        MDIconButton:
            icon: 'keyboard-return'
            theme_text_color: "Custom"
            icon_color: app.theme_cls.accent_color if root.shift_state == 'shifted' else "white"
            size_hint: 1, 1
            on_release:
                root.cmd_sound()
                root.insert_newline()
                root.text_input.focus = True
                Clock.schedule_once(lambda dt: root._ensure_cursor_visible(), 0.05)

<DashboardScreen>:
    name: "dashboard_screen"
    md_bg_color: 0.95, 0.95, 0.95, 1

    MDBoxLayout:
        orientation: 'vertical'
        padding: [root.screen_padding, 0, root.screen_padding, 0]

        MDLabel:
            text:'top margin space'
            halign: 'center'
            size_hint_y: None
            height: root.top_margin

        MDBoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: root.header_height
            padding: [dp(10), 0, dp(10), 0]
            md_bg_color: 0.98, 0.98, 0.98, 1
            spacing: dp(5)

            BoxLayout:
                id: left_button_container
                size_hint_x: None
                width: min(dp(48), root.width * 0.12)
                pos_hint: {"center_y": .5}

                MDIconButton:
                    id: menu_button
                    icon: 'menu'
                    opacity: 1 if root.current_folder_id is None else 0
                    disabled: root.current_folder_id is not None
                    size_hint: 1, 1
                    pos_hint: {"center_y": .5}

                MDIconButton:
                    id: back_button
                    icon: 'arrow-left'
                    opacity: 0 if root.current_folder_id is None else 1
                    disabled: root.current_folder_id is None
                    size_hint: 1, 1
                    pos_hint: {"center_y": .5}
                    on_release:
                        root.go_back_to_dashboard()

            MDLabel:
                id: header_title
                text: 'My Notes' if root.current_folder_id is None else root.get_current_folder_name()
                halign: 'center'
                font_size: max(18, min(24, root.width // 15))
                bold: True
                theme_text_color: "Custom"
                text_color: 0, 0, 1, 1
                size_hint_x: 1
                shorten: True
                shorten_from: 'right'

            MDIconButton:
                icon: 'more'   #view-grid-outline
                size_hint_x: None
                width: min(dp(48), root.width * 0.12)
                pos_hint: {"center_y": .5}
                disabled: True  # Disabled as placeholder

        MDScrollView:
            size_hint: 1, 1
            do_scroll_x: False
            do_scroll_y: True
            bar_width: min(dp(4), root.width * 0.01)
            bar_color: 0.5, 0.5, 0.5, 0.8
            bar_inactive_color: 0.5, 0.5, 0.5, 0.4

            MDBoxLayout:
                orientation: 'vertical'
                padding: [root.screen_padding, root.screen_padding, root.screen_padding, root.screen_padding]
                spacing: root.section_spacing
                size_hint_y: None
                height: self.minimum_height

                GridLayout:
                    id: folders_grid
                    cols: 1
                    spacing: root.grid_spacing
                    size_hint_y: None
                    height: self.minimum_height
                    opacity: 0 if root.current_folder_id is not None else 1
                    disabled: root.current_folder_id is not None

                GridLayout:
                    id: notes_grid
                    cols: 1
                    spacing: root.grid_spacing
                    size_hint_y: None
                    height: self.minimum_height
                    padding: [dp(5), dp(2), dp(6), dp(2)]

    AKFloatingRoundedAppbar:
        id: floating_appbar
        size_hint_y: None
        height: dp(150)
        bg_color: 140/255, 146/255, 172/255, 0.7
        press_effect: True
        radius: [10, 10, 10, 10]

        AKFloatingRoundedAppbarButtonItem:
            icon: "folder-plus-outline"
            text: "New Folder"
            icon_size: min(dp(24), root.width * 0.06)
            text_size: min(dp(12), root.width * 0.03)
            pos_hint: {'y': 1.1}
            color: 0, 0, 1, 1
            on_release: root.create_new_folder()

        AKFloatingRoundedAppbarButtonItem:
            icon: "note-plus-outline"
            text: "New Note"
            icon_size: min(dp(24), root.width * 0.06)
            text_size: min(dp(12), root.width * 0.03)
            pos_hint: {'y': 1.1}
            on_release: root.go_note_screen()

    Widget:
        size_hint_y: None
        height: dp(10)
        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size