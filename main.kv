                Lim_Key_Pad_Button:
                    text: "ᤜ"
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "ᤀ"
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "ᤂ"
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "ᤍ"
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "ᤗ"
                    on_release: root.insert_text(self.text)
