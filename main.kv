                    text: "ᤄ"
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "ᤥ"
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "ᤦ"
                    on_release: root.insert_text(self.text)

                Lim_Key_Pad_Button:
                    text: "ᤰ"
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "ᤱ"
                    on_release: root.insert_text(self.text)
                Lim_Key_Pad_Button:
                    text: "ᤴ"
                    on_release: root.insert_text(self.text)
